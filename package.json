{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Interactive 2D Portfolio Website",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/server.ts",
    "start": "node dist/server.js",
    "build:client": "esbuild public/ts/app.ts --bundle --outfile=public/js/app.js --sourcemap",
    "build:all": "npm run build && npm run build:client",
    "dev:client": "esbuild public/ts/app.ts --bundle --outfile=public/js/app.js --sourcemap --watch"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
